# MirrorTrap environment variables (Vite)
# Copy to `.env.local` and fill in any keys you have.
# Everything is optional — MirrorTrap falls back to deterministic public
# data and curated mocks when keys are missing or rate-limits hit.

# Supabase (auth + edge functions)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Anthropic Claude — used by the AI Attack Path Engine + Chat Assistant
VITE_ANTHROPIC_API_KEY=

# HaveIBeenPwned — Personal Email scan mode
# Get free key at haveibeenpwned.com/API/Key
# Free tier: 10 requests/minute — enough for a hackathon demo
VITE_HIBP_KEY=
